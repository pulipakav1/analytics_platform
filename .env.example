# ── Runtime ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
APP_ENV=development          # development | production

# ── Logging ────────────────────────────────────────────────────────────────────
# Overrides log_level in config/config.yaml when set
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Config ─────────────────────────────────────────────────────────────────────
# Path to the YAML config file (relative to project root)
CONFIG_PATH=config/config.yaml

# ── Data paths (override config.yaml defaults) ─────────────────────────────────
# Leave blank to use config/config.yaml values.
# DATA_RAW_PATH=data/raw/treasury_daily.csv
# DATA_STAGING_PATH=data/staging/treasury_staging.csv
# DATA_CURATED_PATH=data/curated/treasury_curated.csv
# DATA_OUTPUTS_DIR=data/outputs

# ── Forecasting ────────────────────────────────────────────────────────────────
# FORECAST_HORIZON_DAYS=14
# ARIMA_ORDER=2,1,2
